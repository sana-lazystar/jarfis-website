---
// Root redirect to /en/
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="canonical" href={`${base}/en/`} />
    <title>JARFIS</title>
    <script is:inline define:vars={{ base }}>
      window.location.replace(base + '/en/');
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0; url=${base}/en/`} />
    </noscript>
  </head>
  <body>
    <noscript>
      <p>Redirecting to <a href={`${base}/en/`}>/en/</a></p>
    </noscript>
  </body>
</html>
