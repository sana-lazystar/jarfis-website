---
import type { Locale } from '../../i18n/config';
import { localePath } from '../../i18n/utils';
import Button from '../common/Button.astro';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  bullets?: string[];
  docsPath?: string;
  docsLabel?: string;
  githubLink?: boolean;
  githubLabel?: string;
  reverse?: boolean; // alternate layout
  icon?: string;     // SVG string for the visual
}

const {
  locale,
  title,
  description,
  bullets = [],
  docsPath,
  docsLabel = 'Learn more in Docs',
  githubLink = false,
  githubLabel = 'View on GitHub',
  reverse = false,
  icon,
} = Astro.props;
---
<div
  class={`grid lg:grid-cols-2 gap-12 lg:gap-16 items-center ${reverse ? 'lg:[&>*:first-child]:order-2' : ''}`}
>
  <!-- Visual -->
  <div
    class={`flex items-center justify-center rounded-2xl bg-slate-100 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 min-h-[280px] p-8 ${reverse ? 'lg:order-2' : ''}`}
    aria-hidden="true"
  >
    {icon ? (
      <div class="text-cyan-500 dark:text-cyan-400 w-32 h-32 flex items-center justify-center">
        <Fragment set:html={icon} />
      </div>
    ) : (
      <slot name="visual">
        <!-- Default visual placeholder -->
        <div class="w-32 h-32 rounded-full bg-cyan-500/20 flex items-center justify-center">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyan-500">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <path d="M3 9h18"/>
            <path d="M9 21V9"/>
          </svg>
        </div>
      </slot>
    )}
  </div>

  <!-- Text content -->
  <div class={reverse ? 'lg:order-1' : ''}>
    <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-4">
      {title}
    </h3>
    <p class="text-slate-600 dark:text-slate-300 leading-relaxed mb-5">
      {description}
    </p>

    {bullets.length > 0 && (
      <ul class="space-y-2 mb-6">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-2 text-slate-600 dark:text-slate-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-cyan-500 dark:text-cyan-400 mt-0.5 shrink-0" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>{bullet}</span>
          </li>
        ))}
      </ul>
    )}

    <div class="flex flex-wrap gap-3">
      {docsPath && (
        <Button href={localePath(locale, docsPath)} variant="secondary" size="sm">
          {docsLabel}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </Button>
      )}
      {githubLink && (
        <Button
          href="https://github.com/sana-lazystar/jarfis"
          variant="ghost"
          size="sm"
          external={true}
        >
          {githubLabel}
        </Button>
      )}
    </div>
  </div>
</div>
