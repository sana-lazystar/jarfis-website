---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  pubDate: Date;
  author?: string;
  tags?: string[];
  slug: string;
}

const {
  locale,
  title,
  description,
  pubDate,
  author = 'JARFIS Team',
  tags = [],
  slug,
} = Astro.props;

const href = localePath(locale, `blog/${slug}`);
---
<article class="group flex flex-col gap-4 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 p-6 transition-all duration-200 hover:border-cyan-500/50 dark:hover:border-cyan-500/50 hover:-translate-y-0.5 hover:shadow-md">
  <!-- Tags -->
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5" aria-label="Tags">
      {tags.slice(0, 3).map((tag) => (
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-cyan-100 dark:bg-cyan-900/30 text-cyan-700 dark:text-cyan-300 uppercase tracking-wide">
          {tag}
        </span>
      ))}
    </div>
  )}

  <!-- Title -->
  <h3 class="text-lg font-semibold text-slate-900 dark:text-white group-hover:text-cyan-500 dark:group-hover:text-cyan-400 transition-colors leading-snug">
    <a href={href} class="focus-visible:outline-2 focus-visible:outline-cyan-500 focus-visible:outline-offset-2 rounded">
      {title}
    </a>
  </h3>

  <!-- Description -->
  <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed flex-1">
    {description}
  </p>

  <!-- Meta -->
  <div class="flex items-center justify-between pt-2 border-t border-slate-100 dark:border-slate-700">
    <div class="flex items-center gap-2 text-xs text-slate-500 dark:text-slate-400">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString(locale, { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
      {author && (
        <>
          <span aria-hidden="true">&middot;</span>
          <span>{author}</span>
        </>
      )}
    </div>
    <a
      href={href}
      class="text-xs font-medium text-cyan-500 dark:text-cyan-400 hover:underline"
      tabindex="-1"
      aria-hidden="true"
    >
      {t(locale, 'blog.read_more')} →
    </a>
  </div>
</article>
