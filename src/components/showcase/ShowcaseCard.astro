---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/utils';

interface Props {
  locale: Locale;
  name: string;
  description: string;
  url: string;
  repoUrl?: string;
  thumbnail: string;
  tags?: string[];
  featured?: boolean;
}

const {
  locale,
  name,
  description,
  url,
  repoUrl,
  thumbnail,
  tags = [],
  featured = false,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const thumbnailSrc = thumbnail.startsWith('/') ? `${base}${thumbnail}` : thumbnail;
---
<article
  class={`group flex flex-col rounded-xl border overflow-hidden bg-white dark:bg-slate-800/50 transition-all duration-200 hover:-translate-y-1 hover:shadow-lg ${
    featured
      ? 'border-cyan-500/50 dark:border-cyan-500/40 shadow-sm shadow-cyan-500/10'
      : 'border-slate-200 dark:border-slate-700'
  }`}
>
  <!-- Thumbnail -->
  <div class="relative aspect-video bg-slate-100 dark:bg-slate-800 overflow-hidden">
    <img
      src={thumbnailSrc}
      alt={`${name} screenshot`}
      width="400"
      height="225"
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      onerror="this.parentElement.classList.add('flex','items-center','justify-center'); this.style.display='none'; this.parentElement.innerHTML += '<svg width=48 height=48 viewBox=0 0 24 24 fill=none stroke=currentColor stroke-width=1.5 class=text-slate-400><rect x=3 y=3 width=18 height=18 rx=2/><circle cx=8.5 cy=8.5 r=1.5/><polyline points=21,15 16,10 5,21/></svg>';"
    />
    {featured && (
      <div class="absolute top-2 left-2 px-2 py-0.5 rounded text-xs font-semibold bg-cyan-500 text-slate-900">
        Featured
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="flex flex-col gap-3 p-5 flex-1">
    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Name -->
    <h3 class="font-semibold text-slate-900 dark:text-white group-hover:text-cyan-500 dark:group-hover:text-cyan-400 transition-colors">
      {name}
    </h3>

    <!-- Description -->
    <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed flex-1">
      {description}
    </p>

    <!-- Links -->
    <div class="flex items-center gap-3 pt-2 border-t border-slate-100 dark:border-slate-700">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-cyan-500 dark:text-cyan-400 hover:underline flex items-center gap-1"
        aria-label={`View ${name} project (opens in new tab)`}
      >
        {t(locale, 'showcase.view_project')}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
          <polyline points="15,3 21,3 21,9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
      {repoUrl && (
        <>
          <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">|</span>
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 flex items-center gap-1 transition-colors"
            aria-label={`View ${name} source code on GitHub (opens in new tab)`}
          >
            {t(locale, 'showcase.view_source')}
          </a>
        </>
      )}
    </div>
  </div>
</article>
