---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/utils';
import { JARFIS_STATS } from '../../data/stats';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---
<section
  class="py-16 lg:py-20 bg-slate-50 dark:bg-slate-800/30"
  aria-labelledby="social-proof-heading"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 p-8 sm:p-12 text-center shadow-sm">

      <!-- Stats row: 2x2 on mobile, 4-column on sm+ -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-8">
        <!-- Version -->
        <div class="flex flex-col items-center gap-2">
          <div class="flex items-center gap-2 text-3xl font-bold text-slate-900 dark:text-white">
            <!-- Tag/version icon -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-500" aria-hidden="true">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
              <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
            {JARFIS_STATS.version}
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            {t(locale, 'social_proof.version_label')}
          </p>
        </div>

        <!-- Agents -->
        <div class="flex flex-col items-center gap-2">
          <div class="flex items-center gap-2 text-3xl font-bold text-slate-900 dark:text-white">
            <!-- Users/team icon -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-500" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            {JARFIS_STATS.agents}
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            {t(locale, 'social_proof.agents_label')}
          </p>
        </div>

        <!-- Artifacts -->
        <div class="flex flex-col items-center gap-2">
          <div class="flex items-center gap-2 text-3xl font-bold text-slate-900 dark:text-white">
            <!-- File/document icon -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-500" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
            {JARFIS_STATS.artifacts}
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            {t(locale, 'social_proof.artifacts_label')}
          </p>
        </div>

        <!-- Commands -->
        <div class="flex flex-col items-center gap-2">
          <div class="flex items-center gap-2 text-3xl font-bold text-slate-900 dark:text-white">
            <!-- Terminal/command icon -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-500" aria-hidden="true">
              <polyline points="4 17 10 11 4 5"/>
              <line x1="12" y1="19" x2="20" y2="19"/>
            </svg>
            {JARFIS_STATS.commands}
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            {t(locale, 'social_proof.commands_label')}
          </p>
        </div>
      </div>

      <!-- Title -->
      <p
        id="social-proof-heading"
        class="text-lg font-medium text-slate-700 dark:text-slate-200 max-w-lg mx-auto"
      >
        {t(locale, 'social_proof.title')}
      </p>
    </div>
  </div>
</section>
