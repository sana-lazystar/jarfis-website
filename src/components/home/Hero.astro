---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';
import Button from '../common/Button.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---
<section
  class="relative min-h-screen flex items-center overflow-hidden bg-white dark:bg-slate-900"
  aria-labelledby="hero-heading"
>
  <!-- Background gradient glow -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 right-1/4 w-[600px] h-[600px] rounded-full bg-cyan-500/5 dark:bg-cyan-500/10 blur-3xl"></div>
    <div class="absolute bottom-1/4 left-1/4 w-[400px] h-[400px] rounded-full bg-cyan-300/5 dark:bg-cyan-300/10 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-0 w-full">
    <div class="grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-16 items-center">

      <!-- Text content -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-cyan-500/10 dark:bg-cyan-500/20 text-cyan-600 dark:text-cyan-400 border border-cyan-500/20 mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
          </span>
          {t(locale, 'hero.badge')}
        </div>

        <!-- Tagline -->
        <h1
          id="hero-heading"
          class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight text-slate-900 dark:text-white mb-4"
          style="font-size: clamp(2.5rem, 5vw, 4rem);"
          set:html={t(locale, 'hero.tagline')}
        />

        <!-- Subtitle -->
        <p class="text-lg font-medium text-slate-600 dark:text-slate-300 mb-3">
          {t(locale, 'hero.subtitle')}
        </p>

        <!-- Description -->
        <p class="text-base text-slate-500 dark:text-slate-400 max-w-lg mx-auto lg:mx-0 mb-8 leading-relaxed">
          {t(locale, 'hero.description')}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <Button
            href="https://github.com/sana-lazystar/jarfis"
            variant="primary"
            size="lg"
            external={true}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            {t(locale, 'hero.cta_github')}
          </Button>

          <Button
            href={localePath(locale, 'docs/getting-started')}
            variant="secondary"
            size="lg"
          >
            {t(locale, 'hero.cta_start')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="9,18 15,12 9,6"/>
            </svg>
          </Button>
        </div>
      </div>

      <!-- Visual: Orchestration Hub illustration -->
      <div class="flex items-center justify-center lg:justify-end" aria-hidden="true">
        <div class="relative w-64 h-64 sm:w-80 sm:h-80 lg:w-96 lg:h-96">
          <!--
            Orchestration Hub SVG
            viewBox: 0 0 300 300
            9 agent nodes on r=120 ring at 40° intervals starting from -90°
            Node angles (degrees): -90, -50, -10, 30, 70, 110, 150, 190, 230
            Node coords (cx, cy):
              PO:        150, 30    (-90°)
              Architect: 227, 57   (-50°)
              TechLead:  268, 139  (-10°)
              Backend:   242, 224   (30°)
              Frontend:  175, 270   (70°)
              DevOps:     83, 258  (110°)
              QA:         22, 176  (150°)
              Security:   32,  81  (190°)
              UX:        107,  24  (230°)
          -->
          <svg
            viewBox="0 0 300 300"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full h-full text-cyan-500 dark:text-cyan-400"
            aria-hidden="true"
          >
            <defs>
              <!-- Ambient background glow -->
              <radialGradient id="hero-hub-ambient" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="currentColor" stop-opacity="0.10"/>
                <stop offset="100%" stop-color="currentColor" stop-opacity="0"/>
              </radialGradient>
            </defs>

            <!-- Ambient background -->
            <circle cx="150" cy="150" r="140" fill="url(#hero-hub-ambient)"/>

            <!-- Hub-to-Node edges (dashed lines) -->
            <!-- PO: (150, 30) -->
            <line x1="150" y1="150" x2="150" y2="30"
                  stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"
                  opacity="0.25" class="hub-edge"/>
            <!-- Architect: (227, 57) -->
            <line x1="150" y1="150" x2="227" y2="57"
                  stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"
                  opacity="0.25" class="hub-edge"/>
            <!-- TechLead: (268, 139) -->
            <line x1="150" y1="150" x2="268" y2="139"
                  stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"
                  opacity="0.25" class="hub-edge"/>
            <!-- Backend: (242, 224) -->
            <line x1="150" y1="150" x2="242" y2="224"
                  stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"
                  opacity="0.25" class="hub-edge"/>
            <!-- Frontend: (175, 270) -->
            <line x1="150" y1="150" x2="175" y2="270"
                  stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"
                  opacity="0.25" class="hub-edge"/>
            <!-- DevOps: (83, 258) -->
            <line x1="150" y1="150" x2="83" y2="258"
                  stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"
                  opacity="0.25" class="hub-edge"/>
            <!-- QA: (22, 176) -->
            <line x1="150" y1="150" x2="22" y2="176"
                  stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"
                  opacity="0.25" class="hub-edge"/>
            <!-- Security: (32, 81) -->
            <line x1="150" y1="150" x2="32" y2="81"
                  stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"
                  opacity="0.25" class="hub-edge"/>
            <!-- UX: (107, 24) -->
            <line x1="150" y1="150" x2="107" y2="24"
                  stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"
                  opacity="0.25" class="hub-edge"/>

            <!-- Agent node outer rings (animated with stagger) -->
            <!-- PO -->
            <circle cx="150" cy="30" r="10"
                    stroke="currentColor" stroke-width="1.5"
                    fill="none" opacity="0.7"
                    class="agent-node-ring" style="animation-delay: 0s;"/>
            <!-- Architect -->
            <circle cx="227" cy="57" r="10"
                    stroke="currentColor" stroke-width="1.5"
                    fill="none" opacity="0.7"
                    class="agent-node-ring" style="animation-delay: 0.33s;"/>
            <!-- TechLead -->
            <circle cx="268" cy="139" r="10"
                    stroke="currentColor" stroke-width="1.5"
                    fill="none" opacity="0.7"
                    class="agent-node-ring" style="animation-delay: 0.66s;"/>
            <!-- Backend -->
            <circle cx="242" cy="224" r="10"
                    stroke="currentColor" stroke-width="1.5"
                    fill="none" opacity="0.7"
                    class="agent-node-ring" style="animation-delay: 0.99s;"/>
            <!-- Frontend -->
            <circle cx="175" cy="270" r="10"
                    stroke="currentColor" stroke-width="1.5"
                    fill="none" opacity="0.7"
                    class="agent-node-ring" style="animation-delay: 1.32s;"/>
            <!-- DevOps -->
            <circle cx="83" cy="258" r="10"
                    stroke="currentColor" stroke-width="1.5"
                    fill="none" opacity="0.7"
                    class="agent-node-ring" style="animation-delay: 1.65s;"/>
            <!-- QA -->
            <circle cx="22" cy="176" r="10"
                    stroke="currentColor" stroke-width="1.5"
                    fill="none" opacity="0.7"
                    class="agent-node-ring" style="animation-delay: 1.98s;"/>
            <!-- Security -->
            <circle cx="32" cy="81" r="10"
                    stroke="currentColor" stroke-width="1.5"
                    fill="none" opacity="0.7"
                    class="agent-node-ring" style="animation-delay: 2.31s;"/>
            <!-- UX -->
            <circle cx="107" cy="24" r="10"
                    stroke="currentColor" stroke-width="1.5"
                    fill="none" opacity="0.7"
                    class="agent-node-ring" style="animation-delay: 2.64s;"/>

            <!-- Agent node inner dots -->
            <circle cx="150" cy="30"  r="5" fill="currentColor"/>
            <circle cx="227" cy="57"  r="5" fill="currentColor"/>
            <circle cx="268" cy="139" r="5" fill="currentColor"/>
            <circle cx="242" cy="224" r="5" fill="currentColor"/>
            <circle cx="175" cy="270" r="5" fill="currentColor"/>
            <circle cx="83"  cy="258" r="5" fill="currentColor"/>
            <circle cx="22"  cy="176" r="5" fill="currentColor"/>
            <circle cx="32"  cy="81"  r="5" fill="currentColor"/>
            <circle cx="107" cy="24"  r="5" fill="currentColor"/>

            <!-- Agent node role labels (desktop size, small text) -->
            <text x="150" y="16"  text-anchor="middle" fill="currentColor" font-size="6" opacity="0.6" font-family="ui-sans-serif, sans-serif">PO</text>
            <text x="238" y="47"  text-anchor="middle" fill="currentColor" font-size="6" opacity="0.6" font-family="ui-sans-serif, sans-serif">Arc</text>
            <text x="280" y="136" text-anchor="middle" fill="currentColor" font-size="6" opacity="0.6" font-family="ui-sans-serif, sans-serif">TL</text>
            <text x="254" y="238" text-anchor="middle" fill="currentColor" font-size="6" opacity="0.6" font-family="ui-sans-serif, sans-serif">BE</text>
            <text x="175" y="284" text-anchor="middle" fill="currentColor" font-size="6" opacity="0.6" font-family="ui-sans-serif, sans-serif">FE</text>
            <text x="76"  y="272" text-anchor="middle" fill="currentColor" font-size="6" opacity="0.6" font-family="ui-sans-serif, sans-serif">Ops</text>
            <text x="14"  y="190" text-anchor="middle" fill="currentColor" font-size="6" opacity="0.6" font-family="ui-sans-serif, sans-serif">QA</text>
            <text x="20"  y="70"  text-anchor="middle" fill="currentColor" font-size="6" opacity="0.6" font-family="ui-sans-serif, sans-serif">Sec</text>
            <text x="96"  y="13"  text-anchor="middle" fill="currentColor" font-size="6" opacity="0.6" font-family="ui-sans-serif, sans-serif">UX</text>

            <!-- Hub glow ring -->
            <circle cx="150" cy="150" r="35"
                    stroke="currentColor" stroke-width="1"
                    fill="none" opacity="0.3"/>

            <!-- Central JARFIS hexagon hub (flat-top, apothem=26, R=30) -->
            <!-- Points: (180,150)(165,176)(135,176)(120,150)(135,124)(165,124) -->
            <polygon
              points="180,150 165,176 135,176 120,150 135,124 165,124"
              fill="currentColor"
              opacity="0.95"
              class="hub-hexagon"
            />

            <!-- Hub symbol: "/" (slash command identity) -->
            <text
              x="150" y="154"
              text-anchor="middle"
              dominant-baseline="middle"
              fill="white"
              font-size="20"
              font-weight="bold"
              font-family="ui-monospace, 'Courier New', monospace"
            >/</text>
          </svg>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-slate-400 dark:text-slate-500 animate-bounce" aria-hidden="true">
    <span class="text-xs tracking-widest uppercase">scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </div>
</section>

<style>
  /* Node pulse: staggered outer ring animation */
  @keyframes node-pulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50%       { opacity: 0.85; transform: scale(1.15); }
  }

  .agent-node-ring {
    animation: node-pulse 3s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }

  /* Edge flow: dashed line dash-offset animation */
  @keyframes flow {
    from { stroke-dashoffset: 20; }
    to   { stroke-dashoffset: 0; }
  }

  .hub-edge {
    animation: flow 1.5s linear infinite;
  }

  /* Hub breathe: subtle scale pulse on central hexagon */
  @keyframes hub-breathe {
    0%, 100% { transform: scale(1); opacity: 0.95; }
    50%       { transform: scale(1.04); opacity: 1; }
  }

  .hub-hexagon {
    animation: hub-breathe 4s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }

  /* prefers-reduced-motion: stop all animations */
  @media (prefers-reduced-motion: reduce) {
    /* Existing guards (kept for badge ping, scroll bounce) */
    [style*="animation"] {
      animation: none !important;
    }
    .animate-bounce,
    .animate-ping {
      animation: none !important;
    }

    /* SVG CSS class animations */
    .agent-node-ring,
    .hub-edge,
    .hub-hexagon {
      animation: none !important;
      transition: none !important;
    }

    /* Static reduced-motion state */
    .agent-node-ring {
      opacity: 0.5;
    }
  }
</style>
