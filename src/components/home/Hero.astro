---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';
import Button from '../common/Button.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section
  class="relative min-h-screen flex items-center overflow-hidden bg-white dark:bg-slate-900"
  aria-labelledby="hero-heading"
>
  <!-- Background gradient glow -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-1/4 right-1/4 w-[600px] h-[600px] rounded-full bg-cyan-500/5 dark:bg-cyan-500/10 blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-1/4 left-1/4 w-[400px] h-[400px] rounded-full bg-cyan-300/5 dark:bg-cyan-300/10 blur-3xl"
    >
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-0 w-full">
    <div class="grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-16 items-center">
      <!-- Text content -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-cyan-500/10 dark:bg-cyan-500/20 text-cyan-600 dark:text-cyan-400 border border-cyan-500/20 mb-6"
        >
          <span class="relative flex h-2 w-2" aria-hidden="true">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
          </span>
          {t(locale, 'hero.badge')}
        </div>

        <!-- Tagline -->
        {/* eslint-disable jsx-a11y/heading-has-content */}
        <h1
          id="hero-heading"
          class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight text-slate-900 dark:text-white mb-4"
          style="font-size: clamp(2.5rem, 5vw, 4rem);"
          set:html={t(locale, 'hero.tagline')}
        />
        {/* eslint-enable jsx-a11y/heading-has-content */}

        <!-- Subtitle -->
        <p class="text-lg font-medium text-slate-600 dark:text-slate-300 mb-3">
          {t(locale, 'hero.subtitle')}
        </p>

        <!-- Description -->
        <p
          class="text-base text-slate-500 dark:text-slate-400 max-w-lg mx-auto lg:mx-0 mb-8 leading-relaxed"
        >
          {t(locale, 'hero.description')}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <Button
            href="https://github.com/sana-lazystar/jarfis"
            variant="primary"
            size="lg"
            external={true}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
            {t(locale, 'hero.cta_github')}
          </Button>

          <Button href={localePath(locale, 'docs/getting-started')} variant="secondary" size="lg">
            {t(locale, 'hero.cta_start')}
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <polyline points="9,18 15,12 9,6"></polyline>
            </svg>
          </Button>
        </div>
      </div>

      <!-- Visual: Living Orchestration Hub+Orbit Hybrid -->
      <div class="flex items-center justify-center lg:justify-end" aria-hidden="true">
        <div class="hero-orbit-container relative w-56 h-56 md:w-72 md:h-72 lg:w-96 lg:h-96">
          <!--
            Living Orchestration SVG
            viewBox: 0 0 300 300, center (150,150)
            3 tilted elliptical orbits with 3 agents each
            Orbit A (inner):  rx=60  ry=45  tilt=-30deg  -> PO, TL, QA
            Orbit B (middle): rx=90  ry=65  tilt=20deg   -> AR, DO, UX
            Orbit C (outer):  rx=120 ry=85  tilt=-10deg  -> BE, FE, SE
          -->
          <svg
            viewBox="0 0 300 300"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full h-full text-slate-700 dark:text-slate-300"
            aria-hidden="true"
            focusable="false"
          >
            <defs>
              <!-- Ambient background glow -->
              <radialGradient id="hero-hub-ambient" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="currentColor" stop-opacity="0.08"></stop>
                <stop offset="100%" stop-color="currentColor" stop-opacity="0"></stop>
              </radialGradient>
              <!--
                Orbit path definitions (used by CSS offset-path as fallback reference).
                These encode tilted ellipses as two-arc SVG paths.
              -->
              <path
                id="orbit-path-a"
                d="M 201.96 120 A 60 45 -30 0 1 98.04 180 A 60 45 -30 0 1 201.96 120"
                fill="none"></path>
              <path
                id="orbit-path-b"
                d="M 234.57 180.78 A 90 65 20 0 1 65.43 119.22 A 90 65 20 0 1 234.57 180.78"
                fill="none"></path>
              <path
                id="orbit-path-c"
                d="M 268.18 129.16 A 120 85 -10 0 1 31.82 170.84 A 120 85 -10 0 1 268.18 129.16"
                fill="none"></path>
            </defs>

            <!-- Ambient background -->
            <circle cx="150" cy="150" r="140" fill="url(#hero-hub-ambient)"></circle>

            <!-- Radial lines group (6 lines at 60deg intervals, slow rotation) -->
            <g class="radial-lines" opacity="0.15">
              <line x1="150" y1="150" x2="150" y2="10" stroke="currentColor" stroke-width="0.5"
              ></line>
              <line x1="150" y1="150" x2="271.24" y2="80" stroke="currentColor" stroke-width="0.5"
              ></line>
              <line x1="150" y1="150" x2="271.24" y2="220" stroke="currentColor" stroke-width="0.5"
              ></line>
              <line x1="150" y1="150" x2="150" y2="290" stroke="currentColor" stroke-width="0.5"
              ></line>
              <line x1="150" y1="150" x2="28.76" y2="220" stroke="currentColor" stroke-width="0.5"
              ></line>
              <line x1="150" y1="150" x2="28.76" y2="80" stroke="currentColor" stroke-width="0.5"
              ></line>
            </g>

            <!-- Orbit A (inner): rx=60 ry=45 tilt=-30deg, dashed -->
            <ellipse
              cx="150"
              cy="150"
              rx="60"
              ry="45"
              transform="rotate(-30 150 150)"
              stroke="currentColor"
              stroke-width="0.8"
              stroke-dasharray="4 4"
              class="orbit-track orbit-track-a"
              fill="none"></ellipse>

            <!-- Orbit B (middle): rx=90 ry=65 tilt=20deg, dashed -->
            <ellipse
              cx="150"
              cy="150"
              rx="90"
              ry="65"
              transform="rotate(20 150 150)"
              stroke="currentColor"
              stroke-width="0.8"
              stroke-dasharray="5 5"
              class="orbit-track orbit-track-b"
              fill="none"></ellipse>

            <!-- Orbit C (outer): rx=120 ry=85 tilt=-10deg, dashed -->
            <ellipse
              cx="150"
              cy="150"
              rx="120"
              ry="85"
              transform="rotate(-10 150 150)"
              stroke="currentColor"
              stroke-width="0.8"
              stroke-dasharray="6 6"
              class="orbit-track orbit-track-c"
              fill="none"></ellipse>

            <!-- ====== Orbit A agent nodes: PO, TL, QA (clockwise 12s) ====== -->
            <g class="node-orbit-a node-a-0 agent-node" style="--node-stagger: 0s;">
              <circle
                cx="0"
                cy="0"
                r="10"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                class="node-ring"></circle>
              <circle cx="0" cy="0" r="5" fill="currentColor"></circle>
              <text
                x="0"
                y="-14"
                text-anchor="middle"
                fill="currentColor"
                font-size="6"
                opacity="0.6"
                font-family="ui-sans-serif, sans-serif">PO</text
              >
            </g>
            <g class="node-orbit-a node-a-1 agent-node" style="--node-stagger: 0.33s;">
              <circle
                cx="0"
                cy="0"
                r="10"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                class="node-ring"></circle>
              <circle cx="0" cy="0" r="5" fill="currentColor"></circle>
              <text
                x="0"
                y="-14"
                text-anchor="middle"
                fill="currentColor"
                font-size="6"
                opacity="0.6"
                font-family="ui-sans-serif, sans-serif">TL</text
              >
            </g>
            <g class="node-orbit-a node-a-2 agent-node" style="--node-stagger: 0.66s;">
              <circle
                cx="0"
                cy="0"
                r="10"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                class="node-ring"></circle>
              <circle cx="0" cy="0" r="5" fill="currentColor"></circle>
              <text
                x="0"
                y="-14"
                text-anchor="middle"
                fill="currentColor"
                font-size="6"
                opacity="0.6"
                font-family="ui-sans-serif, sans-serif">QA</text
              >
            </g>

            <!-- ====== Orbit B agent nodes: AR, DO, UX (counter-clockwise 18s) ====== -->
            <g class="node-orbit-b node-b-0 agent-node" style="--node-stagger: 0.99s;">
              <circle
                cx="0"
                cy="0"
                r="10"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                class="node-ring"></circle>
              <circle cx="0" cy="0" r="5" fill="currentColor"></circle>
              <text
                x="0"
                y="-14"
                text-anchor="middle"
                fill="currentColor"
                font-size="6"
                opacity="0.6"
                font-family="ui-sans-serif, sans-serif">AR</text
              >
            </g>
            <g class="node-orbit-b node-b-1 agent-node" style="--node-stagger: 1.32s;">
              <circle
                cx="0"
                cy="0"
                r="10"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                class="node-ring"></circle>
              <circle cx="0" cy="0" r="5" fill="currentColor"></circle>
              <text
                x="0"
                y="-14"
                text-anchor="middle"
                fill="currentColor"
                font-size="6"
                opacity="0.6"
                font-family="ui-sans-serif, sans-serif">DO</text
              >
            </g>
            <g class="node-orbit-b node-b-2 agent-node" style="--node-stagger: 1.65s;">
              <circle
                cx="0"
                cy="0"
                r="10"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                class="node-ring"></circle>
              <circle cx="0" cy="0" r="5" fill="currentColor"></circle>
              <text
                x="0"
                y="-14"
                text-anchor="middle"
                fill="currentColor"
                font-size="6"
                opacity="0.6"
                font-family="ui-sans-serif, sans-serif">UX</text
              >
            </g>

            <!-- ====== Orbit C agent nodes: BE, FE, SE (clockwise 24s) ====== -->
            <g class="node-orbit-c node-c-0 agent-node" style="--node-stagger: 1.98s;">
              <circle
                cx="0"
                cy="0"
                r="10"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                class="node-ring"></circle>
              <circle cx="0" cy="0" r="5" fill="currentColor"></circle>
              <text
                x="0"
                y="-14"
                text-anchor="middle"
                fill="currentColor"
                font-size="6"
                opacity="0.6"
                font-family="ui-sans-serif, sans-serif">BE</text
              >
            </g>
            <g class="node-orbit-c node-c-1 agent-node" style="--node-stagger: 2.31s;">
              <circle
                cx="0"
                cy="0"
                r="10"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                class="node-ring"></circle>
              <circle cx="0" cy="0" r="5" fill="currentColor"></circle>
              <text
                x="0"
                y="-14"
                text-anchor="middle"
                fill="currentColor"
                font-size="6"
                opacity="0.6"
                font-family="ui-sans-serif, sans-serif">FE</text
              >
            </g>
            <g class="node-orbit-c node-c-2 agent-node" style="--node-stagger: 2.64s;">
              <circle
                cx="0"
                cy="0"
                r="10"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                class="node-ring"></circle>
              <circle cx="0" cy="0" r="5" fill="currentColor"></circle>
              <text
                x="0"
                y="-14"
                text-anchor="middle"
                fill="currentColor"
                font-size="6"
                opacity="0.6"
                font-family="ui-sans-serif, sans-serif">SE</text
              >
            </g>

            <!-- ====== Central Hub ====== -->

            <!-- Hub glow ring -->
            <circle
              cx="150"
              cy="150"
              r="35"
              stroke="currentColor"
              stroke-width="1"
              fill="none"
              opacity="0.3"
              class="text-slate-800 dark:text-slate-200"></circle>

            <!-- Central JARFIS hexagon hub (flat-top, 42px diameter, R=21) -->
            <polygon
              points="171,150 160.5,168.19 139.5,168.19 129,150 139.5,131.81 160.5,131.81"
              fill="currentColor"
              opacity="0.95"
              class="hub-hexagon text-slate-800 dark:text-slate-200"></polygon>

            <!-- Hub symbol: "/" -->
            <text
              x="150"
              y="154"
              text-anchor="middle"
              dominant-baseline="middle"
              fill="white"
              font-size="18"
              font-weight="bold"
              font-family="ui-monospace, 'Courier New', monospace"
              class="hub-hexagon-text">/</text
            >
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-slate-400 dark:text-slate-500 animate-bounce"
    aria-hidden="true"
  >
    <span class="text-xs tracking-widest uppercase">scroll</span>
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>
</section>

<style>
  /*
   * Living Orchestration Hub+Orbit Hybrid Animations
   * All CSS @keyframes, zero SMIL, zero JS libraries.
   */

  /* ===== Orbit track styling ===== */
  .orbit-track {
    opacity: 0.15;
  }
  :global(.dark) .orbit-track {
    opacity: 0.2;
  }

  /* ===== Radial lines slow rotation (30s) ===== */
  @keyframes radial-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .radial-lines {
    animation: radial-spin 30s linear infinite;
    transform-origin: 150px 150px;
  }

  /* ===== Orbit dash flow effect ===== */
  @keyframes orbit-dash-a {
    from {
      stroke-dashoffset: 0;
    }
    to {
      stroke-dashoffset: -40;
    }
  }
  @keyframes orbit-dash-b {
    from {
      stroke-dashoffset: 0;
    }
    to {
      stroke-dashoffset: 50;
    }
  }
  @keyframes orbit-dash-c {
    from {
      stroke-dashoffset: 0;
    }
    to {
      stroke-dashoffset: -60;
    }
  }
  .orbit-track-a {
    animation: orbit-dash-a 12s linear infinite;
  }
  .orbit-track-b {
    animation: orbit-dash-b 18s linear infinite;
  }
  .orbit-track-c {
    animation: orbit-dash-c 24s linear infinite;
  }

  /* ===== Node orbital motion via offset-path ===== */

  /*
   * Orbit A: rx=60 ry=45 tilt=-30deg, clockwise 12s
   * 3 nodes staggered at 0%, 33%, 67% via negative animation-delay
   */
  @keyframes move-along-path {
    from {
      offset-distance: 0%;
    }
    to {
      offset-distance: 100%;
    }
  }

  .node-orbit-a {
    offset-path: path('M 201.96 120 A 60 45 -30 0 1 98.04 180 A 60 45 -30 0 1 201.96 120');
    offset-rotate: 0deg;
    animation: move-along-path 12s linear infinite;
  }
  .node-a-0 {
    animation-delay: 0s;
  }
  .node-a-1 {
    animation-delay: -4s;
  }
  .node-a-2 {
    animation-delay: -8s;
  }

  /*
   * Orbit B: rx=90 ry=65 tilt=20deg, counter-clockwise 18s
   * Reverse direction achieved via animation-direction: reverse
   */
  .node-orbit-b {
    offset-path: path('M 234.57 180.78 A 90 65 20 0 1 65.43 119.22 A 90 65 20 0 1 234.57 180.78');
    offset-rotate: 0deg;
    animation: move-along-path 18s linear infinite reverse;
  }
  .node-b-0 {
    animation-delay: 0s;
  }
  .node-b-1 {
    animation-delay: -6s;
  }
  .node-b-2 {
    animation-delay: -12s;
  }

  /*
   * Orbit C: rx=120 ry=85 tilt=-10deg, clockwise 24s
   */
  .node-orbit-c {
    offset-path: path(
      'M 268.18 129.16 A 120 85 -10 0 1 31.82 170.84 A 120 85 -10 0 1 268.18 129.16'
    );
    offset-rotate: 0deg;
    animation: move-along-path 24s linear infinite;
  }
  .node-c-0 {
    animation-delay: 0s;
  }
  .node-c-1 {
    animation-delay: -8s;
  }
  .node-c-2 {
    animation-delay: -16s;
  }

  /* ===== Node pulse: opacity 0.7-1.0, staggered by --node-stagger ===== */
  @keyframes node-pulse {
    0%,
    100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
    }
  }
  .node-ring {
    animation: node-pulse 3s ease-in-out infinite;
    animation-delay: var(--node-stagger, 0s);
  }

  /* ===== Hub breathe: scale 0.95-1.05, 4s ===== */
  @keyframes hub-breathe {
    0%,
    100% {
      transform: scale(0.95);
    }
    50% {
      transform: scale(1.05);
    }
  }
  .hub-hexagon {
    animation: hub-breathe 4s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  /* Keep "/" text in sync with hex scale */
  .hub-hexagon-text {
    animation: hub-breathe 4s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }

  /* ===== Fallback: static positioning when offset-path unsupported ===== */
  @supports not (offset-path: path('M 0 0')) {
    /*
     * Fallback: place nodes at fixed positions on their respective orbits.
     * These are the parametric ellipse positions at t=0deg, 120deg, 240deg.
     */

    /* Orbit A fallback (tilt=-30deg, rx=60, ry=45) */
    .node-a-0 {
      transform: translate(201.96px, 120px);
      animation: none;
    }
    .node-a-1 {
      transform: translate(104.46px, 113.03px);
      animation: none;
    }
    .node-a-2 {
      transform: translate(143.58px, 216.97px);
      animation: none;
    }

    /* Orbit B fallback (tilt=20deg, rx=90, ry=65) */
    .node-b-0 {
      transform: translate(234.57px, 180.78px);
      animation: none;
    }
    .node-b-1 {
      transform: translate(79.44px, 97.06px);
      animation: none;
    }
    .node-b-2 {
      transform: translate(135.99px, 272.16px);
      animation: none;
    }

    /* Orbit C fallback (tilt=-10deg, rx=120, ry=85) */
    .node-c-0 {
      transform: translate(268.18px, 129.16px);
      animation: none;
    }
    .node-c-1 {
      transform: translate(41.5px, 97.06px);
      animation: none;
    }
    .node-c-2 {
      transform: translate(140.32px, 273.78px);
      animation: none;
    }
  }

  /* ===== Mobile: disable orbit-c animation, static placement ===== */
  @media (max-width: 767px) {
    .node-orbit-c {
      offset-path: none;
      animation: none !important;
    }
    /* Static positions for orbit-c nodes on mobile */
    .node-c-0 {
      transform: translate(268.18px, 129.16px);
    }
    .node-c-1 {
      transform: translate(41.5px, 97.06px);
    }
    .node-c-2 {
      transform: translate(140.32px, 273.78px);
    }
  }

  /* ===== Accessibility: prefers-reduced-motion ===== */
  @media (prefers-reduced-motion: reduce) {
    /* Stop all Tailwind utility animations */
    .animate-bounce,
    .animate-ping {
      animation: none !important;
    }

    /* Stop all custom SVG animations */
    .radial-lines,
    .orbit-track-a,
    .orbit-track-b,
    .orbit-track-c,
    .node-orbit-a,
    .node-orbit-b,
    .node-orbit-c,
    .node-ring,
    .hub-hexagon,
    .hub-hexagon-text {
      animation: none !important;
      transition: none !important;
    }

    /* Static positions for all orbit nodes */
    .node-a-0 {
      transform: translate(201.96px, 120px);
    }
    .node-a-1 {
      transform: translate(104.46px, 113.03px);
    }
    .node-a-2 {
      transform: translate(143.58px, 216.97px);
    }

    .node-b-0 {
      transform: translate(234.57px, 180.78px);
    }
    .node-b-1 {
      transform: translate(79.44px, 97.06px);
    }
    .node-b-2 {
      transform: translate(135.99px, 272.16px);
    }

    .node-c-0 {
      transform: translate(268.18px, 129.16px);
    }
    .node-c-1 {
      transform: translate(41.5px, 97.06px);
    }
    .node-c-2 {
      transform: translate(140.32px, 273.78px);
    }

    /* Keep nodes visible at static opacity */
