---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const comparisons = [
  { traditional: 'compare.single_ai', jarfis: 'compare.team' },
  { traditional: 'compare.suggestion', jarfis: 'compare.autonomous' },
  { traditional: 'compare.vendor', jarfis: 'compare.selfhost' },
  { traditional: 'compare.completion', jarfis: 'compare.workflow' },
  { traditional: 'compare.blackbox', jarfis: 'compare.transparent' },
];
---
<section
  class="py-20 lg:py-28 bg-white dark:bg-slate-900"
  aria-labelledby="differentiator-heading"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <h2
        id="differentiator-heading"
        class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white"
      >
        {t(locale, 'features.differentiator_title')}
      </h2>
    </div>

    <!-- Comparison table -->
    <div class="rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
      <!-- Header -->
      <div class="grid grid-cols-2 bg-slate-50 dark:bg-slate-800/50">
        <div class="px-6 py-4 border-r border-slate-200 dark:border-slate-700">
          <h3 class="font-semibold text-slate-500 dark:text-slate-400 text-sm">
            {t(locale, 'features.traditional')}
          </h3>
        </div>
        <div class="px-6 py-4">
          <h3 class="font-semibold text-cyan-500 dark:text-cyan-400 text-sm flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <ellipse cx="16" cy="16" rx="13" ry="5" stroke="#06b6d4" stroke-width="1.5" transform="rotate(-30 16 16)"/>
              <ellipse cx="16" cy="16" rx="13" ry="5" stroke="#06b6d4" stroke-width="1.5" transform="rotate(30 16 16)"/>
              <ellipse cx="16" cy="16" rx="13" ry="5" stroke="#06b6d4" stroke-width="1.5"/>
              <circle cx="16" cy="16" r="3" fill="#06b6d4"/>
            </svg>
            {t(locale, 'features.jarfis')}
          </h3>
        </div>
      </div>

      <!-- Rows -->
      {comparisons.map(({ traditional, jarfis }, idx) => (
        <div
          class={`grid grid-cols-2 border-t border-slate-200 dark:border-slate-700 ${idx % 2 === 0 ? 'bg-white dark:bg-slate-900' : 'bg-slate-50/50 dark:bg-slate-800/20'}`}
        >
          <!-- Traditional -->
          <div class="px-6 py-4 border-r border-slate-200 dark:border-slate-700 flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-400 shrink-0" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
            <span class="text-sm text-slate-600 dark:text-slate-400">
              {t(locale, `features.${traditional}`)}
            </span>
          </div>

          <!-- JARFIS -->
          <div class="px-6 py-4 flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-cyan-500 dark:text-cyan-400 shrink-0" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="text-sm font-medium text-slate-900 dark:text-white">
              {t(locale, `features.${jarfis}`)}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Footnote -->
    <p class="text-center text-xs text-slate-400 dark:text-slate-500 mt-4">
      {t(locale, 'features.footnote')}
    </p>
  </div>
</section>
