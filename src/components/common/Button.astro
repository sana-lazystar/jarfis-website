---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  ariaLabel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: className = '',
  type = 'button',
  disabled = false,
  ariaLabel,
} = Astro.props;

const baseClasses =
  'inline-flex items-center justify-center gap-2 font-semibold rounded-lg transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 disabled:opacity-50 disabled:cursor-not-allowed';

const sizeClasses = {
  sm: 'text-sm px-3.5 py-2',
  md: 'text-base px-5 py-2.5',
  lg: 'text-lg px-7 py-3.5',
};

const variantClasses = {
  primary:
    'bg-cyan-500 hover:bg-cyan-400 active:bg-cyan-600 text-slate-900 shadow-sm hover:shadow-cyan-500/25 hover:shadow-md',
  secondary:
    'border-2 border-cyan-500 text-cyan-500 dark:text-cyan-400 hover:bg-cyan-500 hover:text-slate-900 dark:hover:text-slate-900',
  ghost:
    'text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800',
};

const classes = [baseClasses, sizeClasses[size], variantClasses[variant], className]
  .filter(Boolean)
  .join(' ');

const externalProps = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---
{href ? (
  <a
    href={href}
    class={classes}
    aria-label={ariaLabel}
    {...externalProps}
  >
    <slot />
    {external && (
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0">
        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
        <polyline points="15,3 21,3 21,9"/>
        <line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
    )}
  </a>
) : (
  <button
    type={type}
    class={classes}
    disabled={disabled}
    aria-label={ariaLabel}
  >
    <slot />
  </button>
)}
