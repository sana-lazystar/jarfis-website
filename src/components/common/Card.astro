---
interface Props {
  title: string;
  description: string;
  icon?: string; // SVG path string or emoji
  href?: string;
  external?: boolean;
  class?: string;
}

const {
  title,
  description,
  icon,
  href,
  external = false,
  class: className = '',
} = Astro.props;

const externalProps = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};

const cardClasses = `group relative flex flex-col gap-4 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 p-8 transition-all duration-200 hover:border-cyan-500 dark:hover:border-cyan-500 hover:-translate-y-1 hover:shadow-lg hover:shadow-cyan-500/10 ${className}`;
---
{href ? (
  <a href={href} class={cardClasses} {...externalProps}>
    {icon && (
      <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-500/10 dark:bg-cyan-500/20 text-cyan-500 dark:text-cyan-400" aria-hidden="true">
        <Fragment set:html={icon} />
      </div>
    )}
    <h3 class="text-lg font-semibold text-slate-900 dark:text-white group-hover:text-cyan-500 dark:group-hover:text-cyan-400 transition-colors">
      {title}
    </h3>
    <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
      {description}
    </p>
    <slot />
  </a>
) : (
  <div class={cardClasses}>
    {icon && (
      <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-500/10 dark:bg-cyan-500/20 text-cyan-500 dark:text-cyan-400" aria-hidden="true">
        <Fragment set:html={icon} />
      </div>
    )}
    <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
      {title}
    </h3>
    <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
      {description}
    </p>
    <slot />
  </div>
)}
