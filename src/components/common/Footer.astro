---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentYear = new Date().getFullYear();

const footerLinks = {
  project: [
    { label: t(locale, 'footer.github_link'), href: 'https://github.com/sana-lazystar/jarfis', external: true },
    { label: t(locale, 'footer.changelog'), href: 'https://github.com/sana-lazystar/jarfis/blob/main/CHANGELOG.md', external: true },
    { label: t(locale, 'footer.releases'), href: 'https://github.com/sana-lazystar/jarfis/releases', external: true },
  ],
  resources: [
    { label: t(locale, 'footer.documentation'), href: localePath(locale, 'docs'), external: false },
    { label: t(locale, 'footer.quick_start'), href: localePath(locale, 'docs/getting-started'), external: false },
    { label: t(locale, 'footer.features_link'), href: localePath(locale, 'features'), external: false },
  ],
  community: [
    { label: t(locale, 'footer.discussions'), href: 'https://github.com/sana-lazystar/jarfis/discussions', external: true },
    { label: t(locale, 'footer.issues'), href: 'https://github.com/sana-lazystar/jarfis/issues', external: true },
    { label: t(locale, 'footer.contributing'), href: 'https://github.com/sana-lazystar/jarfis/blob/main/CONTRIBUTING.md', external: true },
  ],
};
---
<footer class="border-t border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Logo + tagline -->
    <div class="mb-10">
      <a
        href={localePath(locale, '')}
        class="inline-flex items-center gap-2 font-bold text-slate-900 dark:text-white hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors mb-3"
        aria-label="JARFIS — Home"
      >
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <ellipse cx="16" cy="16" rx="14" ry="6" stroke="#06b6d4" stroke-width="1.5" transform="rotate(-30 16 16)"/>
          <ellipse cx="16" cy="16" rx="14" ry="6" stroke="#06b6d4" stroke-width="1.5" transform="rotate(30 16 16)"/>
          <ellipse cx="16" cy="16" rx="14" ry="6" stroke="#06b6d4" stroke-width="1.5"/>
          <circle cx="16" cy="16" r="3" fill="#06b6d4"/>
        </svg>
        JARFIS
      </a>
      <p class="text-sm text-slate-500 dark:text-slate-400 max-w-xs">
        {t(locale, 'footer.tagline')}
      </p>
    </div>

    <!-- Divider -->
    <hr class="border-slate-200 dark:border-slate-700 mb-10" />

    <!-- Links grid -->
    <nav aria-label="Footer navigation">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">

        <!-- Project -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-4">
            {t(locale, 'footer.project')}
          </h3>
          <ul class="space-y-3">
            {footerLinks.project.map(({ label, href, external }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-slate-600 dark:text-slate-300 hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors"
                  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {label}
                  {external && <span class="sr-only"> (opens in new tab)</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-4">
            {t(locale, 'footer.resources')}
          </h3>
          <ul class="space-y-3">
            {footerLinks.resources.map(({ label, href, external }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-slate-600 dark:text-slate-300 hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors"
                  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Community -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-4">
            {t(locale, 'footer.community')}
          </h3>
          <ul class="space-y-3">
            {footerLinks.community.map(({ label, href, external }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-slate-600 dark:text-slate-300 hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors"
                  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {label}
                  {external && <span class="sr-only"> (opens in new tab)</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </nav>

    <!-- Divider -->
    <hr class="border-slate-200 dark:border-slate-700 mt-10 mb-6" />

    <!-- Copyright -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-slate-500 dark:text-slate-400">
      <p>
        &copy; {currentYear} {t(locale, 'footer.copyright')} &middot;{' '}
        <a
          href="https://github.com/sana-lazystar/jarfis/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors"
        >
          {t(locale, 'footer.license')}
          <span class="sr-only"> (opens in new tab)</span>
        </a>
        &middot;{' '}
        <a
          href="https://github.com/sana-lazystar/jarfis"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors"
        >
          {t(locale, 'footer.built_with')}
          <span class="sr-only"> (opens in new tab)</span>
        </a>
      </p>
    </div>

  </div>
</footer>
