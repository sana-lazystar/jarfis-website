---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import Button from '../components/common/Button.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;

// Detect locale from path for proper lang attribute and navigation links
const segments = currentPath.split('/').filter(Boolean);
const locale = ['ko', 'ja', 'zh'].includes(segments[1] ?? '') ? segments[1] as 'ko' | 'ja' | 'zh' : 'en' as const;

const messages: Record<string, { title: string; description: string; backHome: string }> = {
  en: {
    title: 'Page Not Found',
    description: "The page you're looking for doesn't exist or has been moved.",
    backHome: 'Go back home',
  },
  ko: {
    title: '페이지를 찾을 수 없습니다',
    description: '찾고 계신 페이지가 없거나 이동되었습니다.',
    backHome: '홈으로 돌아가기',
  },
  ja: {
    title: 'ページが見つかりません',
    description: 'お探しのページは存在しないか、移動されました。',
    backHome: 'ホームに戻る',
  },
  zh: {
    title: '页面未找到',
    description: '您要找的页面不存在或已被移动。',
    backHome: '返回首页',
  },
};

const msg = messages[locale] ?? messages.en;
const homeUrl = `${base}/${locale}/`;
---
<BaseLayout title={msg.title} locale={locale}>
  <Header locale={locale} currentPath={currentPath} />

  <main id="main-content" class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <!-- 404 number -->
      <div class="text-8xl font-bold text-cyan-500/20 dark:text-cyan-400/20 mb-4 select-none" aria-hidden="true">
        404
      </div>

      <!-- Atom logo -->
      <div class="flex justify-center mb-8" aria-hidden="true">
        <svg width="64" height="64" viewBox="0 0 32 32" fill="none" class="text-cyan-500 dark:text-cyan-400">
          <ellipse cx="16" cy="16" rx="13" ry="5" stroke="currentColor" stroke-width="1.5" transform="rotate(-30 16 16)"/>
          <ellipse cx="16" cy="16" rx="13" ry="5" stroke="currentColor" stroke-width="1.5" transform="rotate(30 16 16)"/>
          <ellipse cx="16" cy="16" rx="13" ry="5" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="16" cy="16" r="3" fill="currentColor"/>
        </svg>
      </div>

      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">
        {msg.title}
      </h1>
      <p class="text-slate-500 dark:text-slate-400 mb-8">
        {msg.description}
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <Button href={homeUrl} variant="primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          {msg.backHome}
        </Button>
        <Button href="https://github.com/sana-lazystar/jarfis" variant="ghost" external={true}>
          GitHub
        </Button>
      </div>
    </div>
  </main>

  <Footer locale={locale} />

</BaseLayout>
