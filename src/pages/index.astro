---
// Root redirect to /en/
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<html>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${base}/en/`} />
    <link rel="canonical" href={`${base}/en/`} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting to <a href={`${base}/en/`}>/en/</a></p>
  </body>
</html>
