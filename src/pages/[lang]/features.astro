---
import { SUPPORTED_LOCALES, type Locale } from '../../i18n/config';
import { t, tArray } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';
import PageLayout from '../../layouts/PageLayout.astro';
import SEOHead from '../../components/common/SEOHead.astro';
import FeatureDetail from '../../components/features/FeatureDetail.astro';
import Differentiator from '../../components/features/Differentiator.astro';
import Button from '../../components/common/Button.astro';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const locale = lang as Locale;

// Feature SVG icons
const agentTeamSvg = `<svg width="96" height="96" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;

const openSourceSvg = `<svg width="96" height="96" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`;

const productionSvg = `<svg width="96" height="96" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`;

const multilangSvg = `<svg width="96" height="96" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`;

// 9 Agents data — key order matches the display order
const agentKeys = ['po', 'architect', 'tech_lead', 'ux', 'backend', 'frontend', 'devops', 'qa', 'security'] as const;

type AgentKey = (typeof agentKeys)[number];

interface AgentData {
  abbr: string;
  name: string;
  desc: string;
  tags: string[];
}

const agents: AgentData[] = agentKeys.map((key) => ({
  abbr: t(locale, `features.agents.${key}.abbr`),
  name: t(locale, `features.agents.${key}.name`),
  desc: t(locale, `features.agents.${key}.desc`),
  tags: tArray(locale, `features.agents.${key}.tags`),
}));
---
<PageLayout
  title={t(locale, 'features.page_title')}
  description={t(locale, 'seo.features_description')}
  locale={locale}
  pagePath="features"
>
  <SEOHead
    slot="head"
    title={t(locale, 'features.page_title')}
    description={t(locale, 'seo.features_description')}
    locale={locale}
    pagePath="features"
    ogImage="/images/og/og-features.png"
  />

  <!-- Page hero -->
  <section class="py-20 bg-white dark:bg-slate-900 text-center border-b border-slate-200 dark:border-slate-700">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-4">
        {t(locale, 'features.page_title')}
      </h1>
      <p class="text-xl text-slate-500 dark:text-slate-400">
        {t(locale, 'features.page_subtitle')}
      </p>
    </div>
  </section>

  <!-- Feature details (alternating layout) -->
  <section class="py-16 lg:py-24 bg-white dark:bg-slate-900" aria-label="Core features">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-24">

      <!-- Feature 1: AI Agent Team (odd = image left, text right) -->
      <FeatureDetail
        locale={locale}
        title={t(locale, 'features.agent_team_title')}
        description={t(locale, 'features.agent_team_desc')}
        bullets={tArray(locale, 'features.agent_team_bullets')}
        docsPath="docs/concepts-overview"
        docsLabel={t(locale, 'features.learn_more')}
        icon={agentTeamSvg}
        reverse={false}
      />

      <!-- Feature 2: Open Source (even = image right, text left) -->
      <FeatureDetail
        locale={locale}
        title={t(locale, 'features.claude_code_title')}
        description={t(locale, 'features.claude_code_desc')}
        bullets={tArray(locale, 'features.claude_code_bullets')}
        docsPath=""
        githubLink={true}
        githubLabel={t(locale, 'features.view_github')}
        icon={openSourceSvg}
        reverse={true}
      />

      <!-- Feature 3: Production Ready (odd) -->
      <FeatureDetail
        locale={locale}
        title={t(locale, 'features.artifacts_title')}
        description={t(locale, 'features.artifacts_desc')}
        bullets={tArray(locale, 'features.artifacts_bullets')}
        docsPath="docs/getting-started"
        docsLabel={t(locale, 'features.learn_more')}
        icon={productionSvg}
        reverse={false}
      />

      <!-- Feature 4: Multi-language (even) -->
      <FeatureDetail
        locale={locale}
        title={t(locale, 'features.learning_title')}
        description={t(locale, 'features.learning_desc')}
        bullets={tArray(locale, 'features.learning_bullets')}
        docsPath="docs"
        docsLabel={t(locale, 'features.learn_more')}
        icon={multilangSvg}
        reverse={true}
      />

    </div>
  </section>

  <!-- 9 Agent Roster -->
  <section class="py-20 lg:py-28 bg-slate-50 dark:bg-slate-800/20" aria-labelledby="agents-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="text-center mb-14">
        <h2
          id="agents-heading"
          class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-4"
        >
          {t(locale, 'features.agents_section_title')}
        </h2>
        <p class="max-w-2xl mx-auto text-lg text-slate-500 dark:text-slate-400">
          {t(locale, 'features.agents_section_subtitle')}
        </p>
      </div>

      <!-- Agent cards grid -->
      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" role="list">
        {agents.map((agent) => (
          <li class="group relative flex flex-col rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-6 transition-shadow hover:shadow-md">
            <!-- Abbr badge -->
            <div class="mb-4 flex items-center gap-3">
              <span
                class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-cyan-50 dark:bg-cyan-500/10 text-cyan-600 dark:text-cyan-400 font-bold text-sm shrink-0"
                aria-hidden="true"
              >
                {agent.abbr}
              </span>
              <h3 class="font-semibold text-slate-900 dark:text-white leading-tight">
                {agent.name}
              </h3>
            </div>

            <!-- Description -->
            <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed flex-1 mb-4">
              {agent.desc}
            </p>

            <!-- Responsibility tags -->
            {agent.tags.length > 0 && (
              <ul class="flex flex-wrap gap-2" role="list" aria-label="Responsibilities">
                {agent.tags.map((tag) => (
                  <li class="px-2.5 py-0.5 rounded-full bg-slate-100 dark:bg-slate-800 text-xs text-slate-500 dark:text-slate-400">
                    {tag}
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Differentiator section -->
  <Differentiator locale={locale} />

  <!-- Feature CTA -->
  <section class="py-16 bg-slate-50 dark:bg-slate-800/30 text-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">
        {t(locale, 'features.cta_heading')}
      </h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={localePath(locale, 'docs/getting-started')} variant="primary">
          {t(locale, 'hero.cta_start')}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </Button>
        <Button
          href="https://github.com/sana-lazystar/jarfis"
          variant="ghost"
          external={true}
        >
          {t(locale, 'hero.cta_github')}
        </Button>
      </div>
    </div>
  </section>
</PageLayout>
