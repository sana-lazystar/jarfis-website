---
import { SUPPORTED_LOCALES, type Locale } from '../../i18n/config';
import { t } from '../../i18n/utils';
import PageLayout from '../../layouts/PageLayout.astro';
import SEOHead from '../../components/common/SEOHead.astro';
import ShowcaseGrid from '../../components/showcase/ShowcaseGrid.astro';
import EmptyState from '../../components/showcase/EmptyState.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const showcaseItems = await getCollection('showcase');
  return SUPPORTED_LOCALES.map((lang) => ({
    params: { lang },
    props: { showcaseItems },
  }));
}

type Props = {
  showcaseItems: Awaited<ReturnType<typeof getCollection<'showcase'>>>;
};

const { lang } = Astro.params as { lang: Locale };
const locale = lang as Locale;
const { showcaseItems } = Astro.props;

// Sort: featured first, then by addedDate
const sorted = [...showcaseItems].sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.addedDate.getTime() - a.data.addedDate.getTime();
});
---
<PageLayout
  title={t(locale, 'showcase.page_title')}
  description={t(locale, 'showcase.page_subtitle')}
  locale={locale}
  pagePath="showcase"
>
  <SEOHead
    slot="head"
    title={t(locale, 'showcase.page_title')}
    description={t(locale, 'showcase.page_subtitle')}
    locale={locale}
    pagePath="showcase"
  />

  <!-- Page header -->
  <section class="py-16 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-4">
        {t(locale, 'showcase.page_title')}
      </h1>
      <p class="text-xl text-slate-500 dark:text-slate-400">
        {t(locale, 'showcase.page_subtitle')}
      </p>
    </div>
  </section>

  <!-- Showcase content -->
  <section class="py-12 lg:py-16 bg-slate-50 dark:bg-slate-800/20 min-h-[50vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {sorted.length > 0 ? (
        <ShowcaseGrid locale={locale} items={sorted} />
      ) : (
        <EmptyState locale={locale} />
      )}
    </div>
  </section>
</PageLayout>
