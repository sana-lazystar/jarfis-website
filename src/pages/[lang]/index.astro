---
import { SUPPORTED_LOCALES, type Locale } from '../../i18n/config';
import { t } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';
import PageLayout from '../../layouts/PageLayout.astro';
import SEOHead from '../../components/common/SEOHead.astro';
import Hero from '../../components/home/Hero.astro';
import ValueProposition from '../../components/home/ValueProposition.astro';
import HowItWorks from '../../components/home/HowItWorks.astro';
import SocialProof from '../../components/home/SocialProof.astro';
import Button from '../../components/common/Button.astro';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const locale = lang as Locale;
---
<PageLayout
  title={t(locale, 'hero.tagline')}
  description={t(locale, 'seo.home_description')}
  locale={locale}
  pagePath=""
>
  <SEOHead
    slot="head"
    title={t(locale, 'hero.tagline')}
    description={t(locale, 'seo.home_description')}
    locale={locale}
    pagePath=""
    ogImage="/images/og/og-default.png"
  />

  <!-- Hero section -->
  <Hero locale={locale} />

  <!-- Value proposition -->
  <ValueProposition locale={locale} />

  <!-- How it works -->
  <HowItWorks locale={locale} />

  <!-- Social proof -->
  <SocialProof locale={locale} />

  <!-- Final CTA section -->
  <section class="py-20 lg:py-28 bg-white dark:bg-slate-900 text-center" aria-labelledby="final-cta-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2
        id="final-cta-heading"
        class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-8"
      >
        {t(locale, 'final_cta.title')}
      </h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button
          href="https://github.com/sana-lazystar/jarfis"
          variant="primary"
          size="lg"
          external={true}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          {t(locale, 'final_cta.cta_github')}
        </Button>

        <Button
          href={localePath(locale, 'docs')}
          variant="secondary"
          size="lg"
        >
          {t(locale, 'final_cta.cta_docs')}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>
</PageLayout>
