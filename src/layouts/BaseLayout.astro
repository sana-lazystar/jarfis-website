---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  ogImage?: string;
}

const {
  title,
  locale = 'en',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const skipLinkText = t(locale, 'a11y.skip_to_content');
---
<!doctype html>
<html lang={locale} class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- CSP meta tag -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'sha256-YxoZ2MkHPm7JhpdQMpPcR2zzwr+kXOnKPUSzcRcVT2U=' 'sha256-L3iAYqJIVqzqYvXPglzHAbfWlt6zvRexBR8UdGt2w6k=' 'sha256-i7B83grpnZ50Ie1ZPI6g8dcZHjVRrScrhW6BkMiJkIg=' 'sha256-PnUcEx1UHK1H7d3wmDWG9Q432uxxlw+yUNhvsu+yRAg=' 'sha256-hpYVaf8zNYm0fxkQMeRkiqB9NR9t/DmmHVHQTRi5ZfY=' 'sha256-1Tmstdrt/2FtKVNF7yMJKMlreVG4bHNyWVQCcZDTF7w=' 'sha256-0JoSUCUEYi9ApLxzFOOE9aRSeJoYkeEwwmVFh8/ndCM='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; base-uri 'self'; upgrade-insecure-requests;"
    />

    <!-- Primary Meta (fallback — SEOHead overrides via slot="head") -->
    <title>{title} | JARFIS</title>
    <meta name="theme-color" content="#06b6d4" />
    <meta name="color-scheme" content="light dark" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" type="image/x-icon" href={`${base}/favicon.ico`} />

    <!-- Head slot for additional meta tags (hreflang, etc.) -->
    <slot name="head" />

    <!-- FOUC prevention: Dark mode inline script (must be before first paint) -->
    <!-- Uses textContent-safe localStorage, no innerHTML manipulation -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored === 'dark' || stored === 'light' ? stored : (prefersDark ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 transition-colors duration-300 antialiased">
    <!-- Skip to main content link (WCAG 2.4.1) -->
    <a
      href="#main-content"
      class="skip-link"
      tabindex="0"
    >
      {skipLinkText}
    </a>

    <slot />
  </body>
</html>

<style is:global>
  html.dark {
    color-scheme: dark;
  }

  /* Focus visible styles for keyboard navigation */
  :focus-visible {
    outline: 2px solid #06b6d4;
    outline-offset: 2px;
  }

  /* Remove focus outline for mouse users */
  :focus:not(:focus-visible) {
    outline: none;
  }

  /* Prose accessibility enhancements */
  .prose a:focus-visible {
    outline: 2px solid #06b6d4;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Ensure sufficient color contrast for muted text */
  .text-slate-400 {
    /* Minimum 4.5:1 contrast ratio on white bg */
    color: #94a3b8; /* slate-400 — meets 3:1 on white (AA for large text) */
  }

  /* High-contrast focus styles for interactive elements */
  button:focus-visible,
  a:focus-visible,
  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    outline: 2px solid #06b6d4;
    outline-offset: 2px;
  }
</style>
