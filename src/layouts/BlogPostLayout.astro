---
import type { Locale } from '../i18n/config';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import { localePath } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  pubDate?: Date;
  author?: string;
  tags?: string[];
  ogImage?: string;
}

const {
  title,
  description,
  locale = 'en',
  pubDate,
  author = 'JARFIS Team',
  tags = [],
  ogImage,
} = Astro.props;

const currentPath = Astro.url.pathname;
---
<BaseLayout title={title} description={description} locale={locale} ogImage={ogImage}>
  <slot name="head" slot="head" />

  <Header locale={locale} currentPath={currentPath} />

  <main id="main-content" class="min-h-screen">
    <!-- Back to blog link -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-8">
      <a
        href={localePath(locale, 'blog')}
        class="inline-flex items-center gap-1 text-sm text-slate-500 dark:text-slate-400 hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Blog
      </a>
    </div>

    <!-- Post header -->
    <header class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-4 leading-tight">
        {title}
      </h1>

      <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500 dark:text-slate-400 mb-4">
        {pubDate && (
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        )}
        {author && (
          <>
            <span aria-hidden="true">&middot;</span>
            <span>{author}</span>
          </>
        )}
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2" aria-label="Tags">
          {tags.map((tag) => (
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-cyan-100 dark:bg-cyan-900/30 text-cyan-800 dark:text-cyan-300 uppercase tracking-wide">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <hr class="border-slate-200 dark:border-slate-700" />
    </div>

    <article class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
      <div class="prose dark:prose-invert max-w-none">
        <slot />
      </div>
    </article>

    <nav
      class="max-w-3xl mx-auto px-4 sm:px-6 pb-12 pt-6 border-t border-slate-200 dark:border-slate-700 flex justify-between gap-4"
      aria-label="Blog post navigation"
    >
      <slot name="prev-next" />
    </nav>
  </main>

  <Footer locale={locale} />
</BaseLayout>
