{
  "$ref": "#/definitions/showcase",
  "definitions": {
    "showcase": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        }
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "repoUrl": {
            "type": "string",
            "format": "uri"
          },
          "thumbnail": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "featured": {
            "type": "boolean",
            "default": false
          },
          "addedDate": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "integer",
                "format": "unix-time"
              }
            ]
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "url",
          "thumbnail",
          "addedDate"
        ],
        "additionalProperties": false
      }
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}